# Binary Bot Configuration
# Copy this file to .env and fill in your credentials

# ============================================================================
# IQ OPTION CREDENTIALS
# ============================================================================
# Your IQ Option account email
IQ_USERNAME=your_email@example.com

# Your IQ Option account password
IQ_PASSWORD=your_password_here

# Balance mode: PRACTICE or REAL
# ⚠️  WARNING: REAL mode trades with actual money!
# Always test with PRACTICE mode first
IQ_BALANCE_MODE=PRACTICE

# ============================================================================
# LOGGING
# ============================================================================
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
